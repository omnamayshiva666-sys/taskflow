# Copy this file's contents into Vercel → Project → Settings → Environment Variables
# (Do NOT commit a real .env file with real secrets to GitHub.)

# ── Supabase (required) ──────────────────────────────────────
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=paste-your-service_role-key-here

# ── Email (optional) ─────────────────────────────────────────
# Sign up free at https://resend.com to enable task/welcome/reminder emails.
# Leave blank to simply skip sending emails (everything else still works).
RESEND_API_KEY=
EMAIL_FROM=Task Management <onboarding@resend.dev>

# ── Cron protection (optional but recommended) ───────────────
# Any random string. Vercel automatically sends it as a Bearer token
# when it calls your /api/cron-* endpoints on schedule.
CRON_SECRET=change-this-to-a-random-string
